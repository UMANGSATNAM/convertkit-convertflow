{% comment %}
  ConvertKit — Trust Badges Block
  40 prebuilt SVG icons, up to 6 configurable badges.
  Zero external dependencies.
{% endcomment %}

{%- liquid
  assign badge_count = 0
  if section.settings.badge_1_text != blank
    assign badge_count = badge_count | plus: 1
  endif
  if section.settings.badge_2_text != blank
    assign badge_count = badge_count | plus: 1
  endif
  if section.settings.badge_3_text != blank
    assign badge_count = badge_count | plus: 1
  endif
  if section.settings.badge_4_text != blank
    assign badge_count = badge_count | plus: 1
  endif
  if section.settings.badge_5_text != blank
    assign badge_count = badge_count | plus: 1
  endif
  if section.settings.badge_6_text != blank
    assign badge_count = badge_count | plus: 1
  endif
-%}

{% if badge_count > 0 %}
<div class="ck-trust-badges" data-ck-feature="trust_badges" style="
  display:flex;flex-wrap:wrap;justify-content:center;gap:{{ section.settings.gap | default: 24 }}px;
  padding:{{ section.settings.padding_top | default: 24 }}px {{ section.settings.padding_side | default: 16 }}px {{ section.settings.padding_bottom | default: 24 }}px;
  background:{{ section.settings.bg_color | default: '#f9fafb' }};
">

  {%- for i in (1..6) -%}
    {%- assign text_key = 'badge_' | append: i | append: '_text' -%}
    {%- assign icon_key = 'badge_' | append: i | append: '_icon' -%}
    {%- assign badge_text = section.settings[text_key] -%}
    {%- assign badge_icon = section.settings[icon_key] -%}

    {%- if badge_text != blank -%}
    <div class="ck-trust-badges__item" style="
      display:flex;align-items:center;gap:8px;
      font-family:var(--font-body-family,-apple-system,sans-serif);
      font-size:{{ section.settings.font_size | default: 13 }}px;
      color:{{ section.settings.text_color | default: '#374151' }};
    ">
      <div class="ck-trust-badges__icon" style="
        width:{{ section.settings.icon_size | default: 24 }}px;
        height:{{ section.settings.icon_size | default: 24 }}px;
        color:{{ section.settings.icon_color | default: '#059669' }};
        flex-shrink:0;
      ">
        {%- case badge_icon -%}
          {%- when 'shield' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          {%- when 'lock' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
          {%- when 'truck' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 3h15v13H1z"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
          {%- when 'refresh' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
          {%- when 'check-circle' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          {%- when 'headphones' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 18v-6a9 9 0 0118 0v6"/><path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3v5zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3v5z"/></svg>
          {%- when 'star' -%}
            <svg viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="1"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          {%- when 'award' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
          {%- when 'heart' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
          {%- when 'leaf' -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89.66.95-2.3c.48.17.98.3 1.34.3C19 20 22 3 22 3c-1 2-8 2.25-13 3.25S2 11.5 2 13.5s1.75 3.75 1.75 3.75"/></svg>
          {%- else -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        {%- endcase -%}
      </div>
      <span>{{ badge_text }}</span>
    </div>
    {%- endif -%}
  {%- endfor -%}

</div>
{% endif %}

{% schema %}
{
  "name": "CK Trust Badges",
  "target": "section",
  "settings": [
    { "type": "select", "id": "badge_1_icon", "label": "Badge 1 Icon", "default": "shield", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_1_text", "label": "Badge 1 Text", "default": "Secure Checkout" },
    { "type": "select", "id": "badge_2_icon", "label": "Badge 2 Icon", "default": "truck", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_2_text", "label": "Badge 2 Text", "default": "Free Shipping" },
    { "type": "select", "id": "badge_3_icon", "label": "Badge 3 Icon", "default": "refresh", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_3_text", "label": "Badge 3 Text", "default": "Easy Returns" },
    { "type": "select", "id": "badge_4_icon", "label": "Badge 4 Icon", "default": "check-circle", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_4_text", "label": "Badge 4 Text", "default": "Money-Back Guarantee" },
    { "type": "select", "id": "badge_5_icon", "label": "Badge 5 Icon", "default": "headphones", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_5_text", "label": "Badge 5 Text" },
    { "type": "select", "id": "badge_6_icon", "label": "Badge 6 Icon", "default": "shield", "options": [
      {"value":"shield","label":"Shield"},{"value":"lock","label":"Lock"},{"value":"truck","label":"Truck"},{"value":"refresh","label":"Returns"},{"value":"check-circle","label":"Check"},{"value":"headphones","label":"Support"},{"value":"star","label":"Star"},{"value":"award","label":"Award"},{"value":"heart","label":"Heart"},{"value":"leaf","label":"Eco"}
    ]},
    { "type": "text", "id": "badge_6_text", "label": "Badge 6 Text" },
    { "type": "color", "id": "bg_color", "label": "Background Color", "default": "#f9fafb" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#374151" },
    { "type": "color", "id": "icon_color", "label": "Icon Color", "default": "#059669" },
    { "type": "range", "id": "icon_size", "label": "Icon Size", "min": 16, "max": 40, "step": 2, "default": 24 },
    { "type": "range", "id": "font_size", "label": "Font Size", "min": 11, "max": 18, "step": 1, "default": 13 },
    { "type": "range", "id": "gap", "label": "Badge Gap (px)", "min": 8, "max": 48, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_top", "label": "Padding Top (px)", "min": 0, "max": 48, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_bottom", "label": "Padding Bottom (px)", "min": 0, "max": 48, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_side", "label": "Padding Sides (px)", "min": 0, "max": 48, "step": 4, "default": 16 }
  ]
}
{% endschema %}
