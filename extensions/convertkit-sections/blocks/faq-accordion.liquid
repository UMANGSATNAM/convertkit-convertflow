{% comment %}
  ConvertKit — FAQ Accordion Block
  Up to 10 FAQ pairs via blocks. Schema.org FAQPage markup.
  Pure CSS open/close animation (no JS required).
  Mobile: 44px min tap target.
{% endcomment %}

<div class="ck-faq"
  data-ck-feature="faq_accordion"
  style="
    max-width:{{ section.settings.max_width | default: 800 }}px;
    margin:{{ section.settings.margin_y | default: 24 }}px auto;
    padding:0 {{ section.settings.padding_x | default: 16 }}px;
    font-family:var(--font-body-family,-apple-system,sans-serif);
  ">

  {% if section.settings.heading != blank %}
    <h2 style="
      text-align:{{ section.settings.heading_align | default: 'center' }};
      font-size:{{ section.settings.heading_size | default: 24 }}px;
      color:{{ section.settings.heading_color | default: '#111827' }};
      margin:0 0 20px;
      font-family:var(--font-heading-family,sans-serif);
    ">{{ section.settings.heading }}</h2>
  {% endif %}

  {%- for block in section.blocks -%}
    {%- if block.settings.question != blank -%}
    <details class="ck-faq__item" {{ block.shopify_attributes }} style="
      border-bottom:1px solid {{ section.settings.border_color | default: '#e5e7eb' }};
    ">
      <summary style="
        display:flex;align-items:center;justify-content:space-between;
        padding:16px 0;cursor:pointer;list-style:none;
        min-height:44px;
        font-weight:600;font-size:{{ section.settings.q_size | default: 15 }}px;
        color:{{ section.settings.q_color | default: '#111827' }};
      ">
        <span>{{ block.settings.question }}</span>
        <svg class="ck-faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;transition:transform 200ms ease"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div class="ck-faq__answer" style="
        padding:0 0 16px;
        font-size:{{ section.settings.a_size | default: 14 }}px;
        color:{{ section.settings.a_color | default: '#4b5563' }};
        line-height:1.6;
      ">
        {{ block.settings.answer }}
      </div>
    </details>
    {%- endif -%}
  {%- endfor -%}
</div>

{%- comment -%} Schema.org FAQPage structured data {%- endcomment -%}
{% if section.blocks.size > 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for block in section.blocks -%}
      {%- if block.settings.question != blank -%}
      {
        "@type": "Question",
        "name": {{ block.settings.question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ block.settings.answer | strip_html | json }}
        }
      }{% unless forloop.last %},{% endunless %}
      {%- endif -%}
    {%- endfor -%}
  ]
}
</script>
{% endif %}

<style>
  .ck-faq__item summary::-webkit-details-marker { display: none; }
  .ck-faq__item summary::marker { display: none; content: ''; }
  .ck-faq__item[open] .ck-faq__chevron { transform: rotate(180deg); }
  .ck-faq__answer { overflow: hidden; }
</style>

{% schema %}
{
  "name": "CK FAQ Accordion",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Frequently Asked Questions" },
    { "type": "select", "id": "heading_align", "label": "Heading Alignment", "default": "center", "options": [
      {"value":"left","label":"Left"},{"value":"center","label":"Center"},{"value":"right","label":"Right"}
    ]},
    { "type": "color", "id": "heading_color", "label": "Heading Color", "default": "#111827" },
    { "type": "color", "id": "q_color", "label": "Question Color", "default": "#111827" },
    { "type": "color", "id": "a_color", "label": "Answer Color", "default": "#4b5563" },
    { "type": "color", "id": "border_color", "label": "Border Color", "default": "#e5e7eb" },
    { "type": "range", "id": "heading_size", "label": "Heading Size", "min": 16, "max": 36, "step": 2, "default": 24 },
    { "type": "range", "id": "q_size", "label": "Question Size", "min": 13, "max": 20, "step": 1, "default": 15 },
    { "type": "range", "id": "a_size", "label": "Answer Size", "min": 12, "max": 18, "step": 1, "default": 14 },
    { "type": "range", "id": "max_width", "label": "Max Width (px)", "min": 400, "max": 1200, "step": 50, "default": 800 },
    { "type": "range", "id": "margin_y", "label": "Vertical Margin", "min": 0, "max": 48, "step": 4, "default": 24 },
    { "type": "range", "id": "padding_x", "label": "Side Padding", "min": 0, "max": 48, "step": 4, "default": 16 }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question" },
        { "type": "richtext", "id": "answer", "label": "Answer" }
      ]
    }
  ],
  "presets": [{
    "name": "CK FAQ Accordion",
    "blocks": [
      { "type": "faq", "settings": { "question": "What is your return policy?", "answer": "<p>We offer a 30-day money-back guarantee on all products.</p>" }},
      { "type": "faq", "settings": { "question": "How long does shipping take?", "answer": "<p>Standard shipping takes 3-5 business days.</p>" }},
      { "type": "faq", "settings": { "question": "Do you offer free shipping?", "answer": "<p>Yes, free shipping on all orders over $50.</p>" }}
    ]
  }]
}
{% endschema %}
