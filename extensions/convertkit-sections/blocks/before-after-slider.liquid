{% comment %}
  ConvertKit — Before/After Slider Block
  Touch-enabled drag slider using CSS clip-path.
  Keyboard accessible with arrow key support.
{% endcomment %}

{%- assign before_img = section.settings.before_image -%}
{%- assign after_img = section.settings.after_image -%}

{% if before_img != blank and after_img != blank %}
<div class="ck-ba-slider"
  id="ck-ba-{{ section.id }}"
  data-ck-feature="before_after"
  role="slider"
  aria-label="{{ section.settings.heading | default: 'Before and after comparison' }}"
  aria-valuemin="0"
  aria-valuemax="100"
  aria-valuenow="50"
  tabindex="0"
  style="
    position:relative;overflow:hidden;cursor:col-resize;
    max-width:{{ section.settings.max_width | default: 800 }}px;
    margin:{{ section.settings.margin_y | default: 24 }}px auto;
    border-radius:{{ section.settings.border_radius | default: 8 }}px;
    user-select:none;-webkit-user-select:none;
  ">

  {% if section.settings.heading != blank %}
    <h3 style="text-align:center;margin:0 0 12px;font-family:var(--font-heading-family,sans-serif);font-size:20px;color:{{ section.settings.text_color | default: '#111' }}">
      {{ section.settings.heading }}
    </h3>
  {% endif %}

  <div class="ck-ba-slider__wrap" style="position:relative;line-height:0">
    <img class="ck-ba-slider__after" src="{{ after_img | image_url: width: 1200 }}" alt="{{ section.settings.after_label | default: 'After' }}" style="width:100%;display:block" loading="lazy">
    <div class="ck-ba-slider__before" style="position:absolute;inset:0;overflow:hidden;width:50%">
      <img src="{{ before_img | image_url: width: 1200 }}" alt="{{ section.settings.before_label | default: 'Before' }}" style="width:100%;height:100%;object-fit:cover;display:block" loading="lazy">
    </div>
    <div class="ck-ba-slider__handle" style="
      position:absolute;top:0;bottom:0;left:50%;width:4px;
      background:{{ section.settings.handle_color | default: '#fff' }};
      transform:translateX(-50%);
      box-shadow:0 0 8px rgba(0,0,0,0.3);
      z-index:2;
    ">
      <div style="
        position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
        width:36px;height:36px;border-radius:50%;
        background:{{ section.settings.handle_color | default: '#fff' }};
        box-shadow:0 2px 8px rgba(0,0,0,0.2);
        display:flex;align-items:center;justify-content:center;
      ">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.text_color | default: '#111' }}" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.text_color | default: '#111' }}" stroke-width="2.5" style="margin-left:-4px"><polyline points="9 18 15 12 9 6"/></svg>
      </div>
    </div>

    {% if section.settings.show_labels %}
    <span style="position:absolute;bottom:12px;left:12px;background:rgba(0,0,0,0.6);color:#fff;padding:3px 8px;border-radius:4px;font-size:12px;z-index:3">
      {{ section.settings.before_label | default: 'Before' }}
    </span>
    <span style="position:absolute;bottom:12px;right:12px;background:rgba(0,0,0,0.6);color:#fff;padding:3px 8px;border-radius:4px;font-size:12px;z-index:3">
      {{ section.settings.after_label | default: 'After' }}
    </span>
    {% endif %}
  </div>
</div>

<script>
(function() {
  var el = document.getElementById('ck-ba-{{ section.id }}');
  if (!el) return;
  var wrap = el.querySelector('.ck-ba-slider__wrap');
  var before = el.querySelector('.ck-ba-slider__before');
  var handle = el.querySelector('.ck-ba-slider__handle');
  var dragging = false;

  function setPosition(x) {
    var rect = wrap.getBoundingClientRect();
    var pct = Math.max(0, Math.min(100, ((x - rect.left) / rect.width) * 100));
    before.style.width = pct + '%';
    handle.style.left = pct + '%';
    el.setAttribute('aria-valuenow', Math.round(pct));
  }

  wrap.addEventListener('mousedown', function(e) { dragging = true; setPosition(e.clientX); });
  document.addEventListener('mousemove', function(e) { if (dragging) { e.preventDefault(); setPosition(e.clientX); } });
  document.addEventListener('mouseup', function() { dragging = false; });

  wrap.addEventListener('touchstart', function(e) { dragging = true; setPosition(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchmove', function(e) { if (dragging) setPosition(e.touches[0].clientX); }, { passive: true });
  document.addEventListener('touchend', function() { dragging = false; });

  el.addEventListener('keydown', function(e) {
    var rect = wrap.getBoundingClientRect();
    var currentPct = parseFloat(before.style.width) || 50;
    if (e.key === 'ArrowLeft' || e.key === 'ArrowDown') { e.preventDefault(); setPosition(rect.left + (currentPct - 2) / 100 * rect.width); }
    if (e.key === 'ArrowRight' || e.key === 'ArrowUp') { e.preventDefault(); setPosition(rect.left + (currentPct + 2) / 100 * rect.width); }
  });
})();
</script>
{% endif %}

{% schema %}
{
  "name": "CK Before/After Slider",
  "target": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "image_picker", "id": "before_image", "label": "Before Image" },
    { "type": "image_picker", "id": "after_image", "label": "After Image" },
    { "type": "text", "id": "before_label", "label": "Before Label", "default": "Before" },
    { "type": "text", "id": "after_label", "label": "After Label", "default": "After" },
    { "type": "checkbox", "id": "show_labels", "label": "Show Labels", "default": true },
    { "type": "color", "id": "handle_color", "label": "Handle Color", "default": "#ffffff" },
    { "type": "color", "id": "text_color", "label": "Text Color", "default": "#111827" },
    { "type": "range", "id": "max_width", "label": "Max Width (px)", "min": 400, "max": 1200, "step": 50, "default": 800 },
    { "type": "range", "id": "border_radius", "label": "Border Radius", "min": 0, "max": 24, "step": 2, "default": 8 },
    { "type": "range", "id": "margin_y", "label": "Vertical Margin (px)", "min": 0, "max": 48, "step": 4, "default": 24 }
  ]
}
{% endschema %}
